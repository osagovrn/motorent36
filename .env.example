DATABASE_URL="file:./dev.db"

# Telegram уведомления о заявках (@BotFather + узнать chat_id)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# На проде без токена заявки отклоняются (503). Для теста на проде: ALLOW_TELEGRAM_SKIP=1
# ALLOW_TELEGRAM_SKIP=1

# Публичный URL сайта (для OG / sitemap / canonical)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Яндекс.Метрика — только цифры ID
# Цель конверсии в коде: booking_ok (создайте в Метрике с тем же именем)
NEXT_PUBLIC_YANDEX_METRIKA_ID=

# Яндекс.Вебмастер — код из meta name="yandex-verification" content="..."
NEXT_PUBLIC_YANDEX_VERIFICATION=
