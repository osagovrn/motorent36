generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id       Int       @id @default(autoincrement())
  slug     String    @unique
  name     String
  products Product[]
}

model Product {
  id          Int                 @id @default(autoincrement())
  categoryId  Int?
  category    Category?           @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  title       String
  slug        String              @unique
  description String?
  pricePerDay Float
  marketValue Float
  /// JSON array of image URLs
  imageUrls   String              @default("[]")
  brand       String?
  model       String?
  color       String?
  createdAt   DateTime            @default(now())
  attributes  ProductAttribute[]
  bookings    Booking[]
}

model ProductAttribute {
  id             Int     @id @default(autoincrement())
  productId      Int
  product        Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  attributeName  String  @default("size")
  attributeValue String
  stockQuantity  Int     @default(1)
}

/// Заявка на бронь. Статусы: new | cancelled
model Booking {
  id                Int      @id @default(autoincrement())
  productId         Int
  product           Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size              String
  startDate         DateTime
  endDate           DateTime
  days              Int
  totalRentalPrice  Float
  refundableDeposit Float
  totalDueAtPickup  Float
  clientName        String
  phone             String
  contactMethod     String
  status            String   @default("new")
  telegramNotified  Boolean  @default(false)
  createdAt         DateTime @default(now())

  @@index([productId, size, startDate, endDate])
  @@index([phone, createdAt])
}
